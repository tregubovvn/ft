<formulas>
    <formula name="Среднее время цикла транспортного процесса">
        <latex> t_{\text{ц}} = t_{\text{пп}} + t_{\text{п}} + t_{\text{т}} + t_{\text{р}} </latex>
        <symbols>
            <symbol char="t_{\text{ц}}" name="Средняя продолжительность цикла транспортного процесса" />
            <symbol char="t_{\text{пп}}" name="Средняя продолжительность выполнения этапа подачи подвижного состава под погрузку" />
            <symbol char="t_{\text{п}}" name="Средняя продолжительность выполнения этапа погрузки" />
            <symbol char="t_{\text{т}}" name="Средняя продолжительность выполнения этапа транспортирования" />
            <symbol char="t_{\text{р}}" name="Средняя продолжительность выполнения этапа разгрузки" />
        </symbols>
    </formula>
    <formula name="Суммарная продолжительность процесса перевозки груза (первая формула)">
        <latex> T = T_{1} + T_{2} + T_{3} + T_{4} + T_{5} </latex>
        <symbols>
            <symbol char="T" name="Суммарная продолжительность процесса перевозки груза, выполняемого за один транспортный цикл" />
            <symbol char="T_{1}" name="Продолжительность этапа подготовки груза к перевозке, ч" />
            <symbol char="T_{2}" name="Продолжительность этапа погрузки, ч" />
            <symbol char="T_{3}" name="Продолжительность этапа транспортирования, ч" />
            <symbol char="T_{4}" name="Продолжительность этапа разгрузки, ч" />
            <symbol char="T_{5}" name="Продолжительность этапа складирования груза, ч" />
        </symbols>
    </formula>
    <formula name="Продолжительность операций по подготовке груза к перевозке">
        <latex> T_{1} = T_{1}^{\text{п}} + T_{1}^{\text{о}} </latex>
        <symbols>
            <symbol char="T_{1}" name="Продолжительность этапа подготовки груза к перевозке, ч" />
            <symbol char="T_{1}^{\text{п}}" name="Продолжительность операций по подготовке груза к отправке, ч" />
            <symbol char="T_{1}^{\text{о}}" name="Продолжительность ожидания начала перемещения груза, ч" />
        </symbols>
    </formula>
    <formula name="Минимальная продолжительность ожидания начала перемещения груза">
        <latex> T_{1}^{\text{о}} \geq t_{\text{пп}} </latex>
        <symbols>
            <symbol char="T_{1}^{\text{о}}" name="Продолжительность ожидания начала перемещения груза, ч" />
            <symbol char="t_{\text{пп}}" name="Продолжительность подачи подвижного состава под погрузку, ч" />
        </symbols>
    </formula>
    <formula name="Продолжительность выполнения погрузочных работ">
        <latex> T_{2} = t_{1}^{\text{п}} + t_{2}^{\text{п}} + T_{3}^{\text{п}} + T_{4}^{\text{п}} </latex>
        <symbols>
            <symbol char="T_{2}" name="Продолжительность этапа погрузки, ч" />
            <symbol char="t_{1}^{\text{п}}" name="Продолжительность выполнения элемента ожидания погрузки, ч" />
            <symbol char="t_{2}^{\text{п}}" name="Продолжительность выполнения элемента маневрирования подвижного состава, ч" />
            <symbol char="T_{3}^{\text{п}}" name="Продолжительность операции погрузки груза, ч" />
            <symbol char="T_{4}^{\text{п}}" name="Продолжительность операции оформления документов, ч" />
        </symbols>
    </formula>
    <formula name="Продолжительность этапа транспортирования">
        <latex> T_{3} = l_{\text{ег}} / v_{\text{T}} </latex>
        <symbols>
            <symbol char="T_{3}" name="Продолжительность этапа транспортирования, ч" />
            <symbol char="l_{\text{ег}}" name="Длина ездки с грузом, км" />
            <symbol char="v_{\text{T}}" name="Техническая скорость, км/ч" />
        </symbols>
    </formula>
    <formula name="Продолжительность этапа разгрузки">
        <latex> T_{4} = t_{1}^{\text{р}} + t_{2}^{\text{р}} + t_{3}^{\text{р}} + t_{4}^{\text{р}} </latex>
        <symbols>
            <symbol char="T_{4}" name="Продолжительность этапа разгрузки, ч" />
            <symbol char="t_{1}^{\text{р}}" name="Продолжительность операции ожидания разгрузки, ч" />
            <symbol char="t_{2}^{\text{р}}" name="Продолжительность операции маневрирования подвижного состава, ч" />
            <symbol char="t_{3}^{\text{р}}" name="Продолжительность операции разгрузки, ч" />
            <symbol char="t_{4}^{\text{р}}" name="Продолжительность операции оформления документов, ч" />
        </symbols>
    </formula>
    <formula name="Продолжительность процесса перевозки груза (расширенная формула)">
        <latex> T = (T_{1}^{\text{п}} + T_{1}^{\text{о}}) + (t_{1}^{\text{п}} + t_{2}^{\text{п}} + T_{3}^{\text{п}} + T_{4}^{\text{п}}) + l_{\text{ег}}/v_{\text{T}} + (t_{1}^{\text{р}} + t_{2}^{\text{р}} + t_{3}^{\text{р}} + t_{4}^{\text{р}}) + T_{5} </latex>
        <symbols>
            <symbol char="T" name="Суммарная продолжительность процесса перевозки груза, выполняемого за один транспортный цикл" />
            <symbol char="T_{1}^{\text{п}}" name="Продолжительность операций по подготовке груза к отправке, ч" />
            <symbol char="T_{1}^{\text{о}}" name="Продолжительность ожидания начала перемещения груза, ч" />
            <symbol char="t_{1}^{\text{п}}" name="Продолжительность выполнения элемента ожидания погрузки, ч" />
            <symbol char="t_{2}^{\text{п}}" name="Продолжительность выполнения элемента маневрирования подвижного состава, ч" />
            <symbol char="T_{3}^{\text{п}}" name="Продолжительность операции погрузки груза, ч" />
            <symbol char="T_{4}^{\text{п}}" name="Продолжительность операции оформления документов, ч" />
            <symbol char="l_{\text{ег}}" name="Длина ездки с грузом, км" />
            <symbol char="v_{\text{T}}" name="Техническая скорость, км/ч" />
            <symbol char="t_{1}^{\text{р}}" name="Продолжительность операции ожидания разгрузки, ч" />
            <symbol char="t_{2}^{\text{р}}" name="Продолжительность операции маневрирования подвижного состава, ч" />
            <symbol char="t_{3}^{\text{р}}" name="Продолжительность операции разгрузки, ч" />
            <symbol char="t_{4}^{\text{р}}" name="Продолжительность операции оформления документов, ч" />
            <symbol char="T_{5}" name="Продолжительность этапа складирования груза, ч" />
        </symbols>
    </formula>
</formulas>
