<formulas>
    <formula name="Среднее время цикла транспортного процесса">
        <latex> t_{ц} = t_{пп} + t_{п} + t_{т} + t_{р} </latex>
        <symbols>
            <symbol char="t_{ц}" name="Средняя продолжительность цикла транспортного процесса" />
            <symbol char="t_{пп}" name="Средняя продолжительность выполнения этапа подачи подвижного состава под погрузку" />
            <symbol char="t_{п}" name="Средняя продолжительность выполнения этапа погрузки" />
            <symbol char="t_{т}" name="Средняя продолжительность выполнения этапа транспортирования" />
            <symbol char="t_{р}" name="Средняя продолжительность выполнения этапа разгрузки" />
        </symbols>
    </formula>
    <formula name="Суммарная продолжительность процесса перевозки груза (первая формула)">
        <latex> T = T_{1} + T_{2} + T_{3} + T_{4} + T_{5} </latex>
        <symbols>
            <symbol char="T" name="Суммарная продолжительность процесса перевозки груза, выполняемого за один транспортный цикл" />
            <symbol char="T_{1}" name="Продолжительность этапа подготовки груза к перевозке, ч" />
            <symbol char="T_{2}" name="Продолжительность этапа погрузки, ч" />
            <symbol char="T_{3}" name="Продолжительность этапа транспортирования, ч" />
            <symbol char="T_{4}" name="Продолжительность этапа разгрузки, ч" />
            <symbol char="T_{5}" name="Продолжительность этапа складирования груза, ч" />
        </symbols>
    </formula>
    <formula name="Продолжительность операций по подготовке груза к перевозке">
        <latex> T_{1} = T_{1}^{п} + T_{1}^{о} </latex>
        <symbols>
            <symbol char="T_{1}" name="Продолжительность этапа подготовки груза к перевозке, ч" />
            <symbol char="T_{1}^{п}" name="Продолжительность операций по подготовке груза к отправке, ч" />
            <symbol char="T_{1}^{о}" name="Продолжительность ожидания начала перемещения груза, ч" />
        </symbols>
    </formula>
    <formula name="Минимальная продолжительность ожидания начала перемещения груза">
        <latex> T_{1}^{о} \geq t_{пп} </latex>
        <symbols>
            <symbol char="T_{1}^{о}" name="Продолжительность ожидания начала перемещения груза, ч" />
            <symbol char="t_{пп}" name="Продолжительность подачи подвижного состава под погрузку, ч" />
        </symbols>
    </formula>
    <formula name="Продолжительность выполнения погрузочных работ">
        <latex> T_{2} = t_{1}^{п} + t_{2}^{п} + T_{3}^{п} + T_{4}^{п} </latex>
        <symbols>
            <symbol char="T_{2}" name="Продолжительность этапа погрузки, ч" />
            <symbol char="t_{1}^{п}" name="Продолжительность выполнения элемента ожидания погрузки, ч" />
            <symbol char="t_{2}^{п}" name="Продолжительность выполнения элемента маневрирования подвижного состава, ч" />
            <symbol char="T_{3}^{п}" name="Продолжительность операции погрузки груза, ч" />
            <symbol char="T_{4}^{п}" name="Продолжительность операции оформления документов, ч" />
        </symbols>
    </formula>
    <formula name="Продолжительность этапа транспортирования">
        <latex> T_{3} = l_{ег} / v_{T} </latex>
        <symbols>
            <symbol char="T_{3}" name="Продолжительность этапа транспортирования, ч" />
            <symbol char="l_{ег}" name="Длина ездки с грузом, км" />
            <symbol char="v_{T}" name="Техническая скорость, км/ч" />
        </symbols>
    </formula>
    <formula name="Продолжительность этапа разгрузки">
        <latex> T_{4} = t_{1}^{р} + t_{2}^{р} + t_{3}^{р} + t_{4}^{р} </latex>
        <symbols>
            <symbol char="T_{4}" name="Продолжительность этапа разгрузки, ч" />
            <symbol char="t_{1}^{р}" name="Продолжительность операции ожидания разгрузки, ч" />
            <symbol char="t_{2}^{р}" name="Продолжительность операции маневрирования подвижного состава, ч" />
            <symbol char="t_{3}^{р}" name="Продолжительность операции разгрузки, ч" />
            <symbol char="t_{4}^{р}" name="Продолжительность операции оформления документов, ч" />
        </symbols>
    </formula>
    <formula name="Продолжительность процесса перевозки груза (расширенная формула)">
        <latex> T = (T_{1}^{п} + T_{1}^{о}) + (t_{1}^{п} + t_{2}^{п} + T_{3}^{п} + T_{4}^{п}) + l_{ег}/v_{T} + (t_{1}^{р} + t_{2}^{р} + t_{3}^{р} + t_{4}^{р}) + T_{5} </latex>
        <symbols>
            <symbol char="T" name="Суммарная продолжительность процесса перевозки груза, выполняемого за один транспортный цикл" />
            <symbol char="T_{1}^{п}" name="Продолжительность операций по подготовке груза к отправке, ч" />
            <symbol char="T_{1}^{о}" name="Продолжительность ожидания начала перемещения груза, ч" />
            <symbol char="t_{1}^{п}" name="Продолжительность выполнения элемента ожидания погрузки, ч" />
            <symbol char="t_{2}^{п}" name="Продолжительность выполнения элемента маневрирования подвижного состава, ч" />
            <symbol char="T_{3}^{п}" name="Продолжительность операции погрузки груза, ч" />
            <symbol char="T_{4}^{п}" name="Продолжительность операции оформления документов, ч" />
            <symbol char="l_{ег}" name="Длина ездки с грузом, км" />
            <symbol char="v_{T}" name="Техническая скорость, км/ч" />
            <symbol char="t_{1}^{р}" name="Продолжительность операции ожидания разгрузки, ч" />
            <symbol char="t_{2}^{р}" name="Продолжительность операции маневрирования подвижного состава, ч" />
            <symbol char="t_{3}^{р}" name="Продолжительность операции разгрузки, ч" />
            <symbol char="t_{4}^{р}" name="Продолжительность операции оформления документов, ч" />
            <symbol char="T_{5}" name="Продолжительность этапа складирования груза, ч" />
        </symbols>
    </formula>
</formulas>
